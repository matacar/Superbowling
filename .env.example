# ──────────────────────────────────────────────────────────────
# Variables de entorno — Super Bowling Medellín
# Copia este archivo a .env.local y completa los valores reales.
# NINGÚN secreto se sube al repo (.env*.local está en .gitignore).
# ──────────────────────────────────────────────────────────────

# URL pública del sitio (para SEO / Open Graph / callbacks de pago)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Supabase (reservas + admin) — se conecta en F2/F3 ──
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ── Wompi (pagos) — se conecta en F3. Usar SANDBOX en desarrollo ──
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=""
WOMPI_PRIVATE_KEY=""
WOMPI_EVENTS_SECRET=""        # para verificar la firma de los webhooks
WOMPI_INTEGRITY_SECRET=""

# ── Resend (emails de confirmación) — se conecta en F3 ──
RESEND_API_KEY=""
